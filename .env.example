# Backend Configuration
BACKEND_PORT=8080
FLASK_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Versioning
NUMO_VERSION=0.1.0

# Frontend Configuration (local development)
VITE_API_URL=http://localhost:8080

# Database Configuration (optional)
# Set DATABASE_URL only for custom database paths or non-SQLite databases
# For local development: defaults to backend/data/numo.db
# For Docker: set to sqlite:////app/data/numo.db (configured in docker-compose.yml)
# DATABASE_URL=sqlite:////app/data/numo.db
